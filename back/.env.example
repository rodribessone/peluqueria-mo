# MongoDB
MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/peluqueria_mo?retryWrites=true&w=majority

# Server
PORT=5000

# Admin credentials (usá el email del salón como usuario)
ADMIN_EMAIL=admin@ejemplo.com
ADMIN_PASSWORD=cambiar_esto

# JWT — generá uno aleatorio con:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Gmail para enviar confirmaciones
# 1. Activá verificación en 2 pasos en tu cuenta Gmail
# 2. Andá a Seguridad > Contraseñas de aplicación
# 3. Generá una contraseña de 16 dígitos y pegala acá
GMAIL_USER=salon@ejemplo.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Nombre del salón (aparece en los emails)
SALON_NAME=M&O Estilistas
SALON_PHONE=+54 9 11 0000-0000

# Replicate (para la IA de cambio de look)
REPLICATE_API_TOKEN=

# CORS — en producción poné tu dominio (separá con coma si hay varios)
# CORS_ORIGIN=https://tudominio.com
